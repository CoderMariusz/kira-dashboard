# KiraBoard Configuration

# ───────────────────────────────────────────────────────────────────────────────
# REQUIRED: OpenClaw Bridge URL
# This is the endpoint for OpenClaw/Bridge API proxy
# ───────────────────────────────────────────────────────────────────────────────
BRIDGE_URL=http://localhost:8199

# ───────────────────────────────────────────────────────────────────────────────
# REQUIRED: JWT Secret for signing authentication tokens
# ⚠️  CHANGE THIS — generate: openssl rand -base64 32
# ───────────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-random-string-in-production

# ───────────────────────────────────────────────────────────────────────────────
# REQUIRED: SQLite Database Path
# Path to the SQLite database file (relative or absolute)
# ───────────────────────────────────────────────────────────────────────────────
KB_DB_PATH=./kiraboard.db

# ───────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Server Configuration
# ───────────────────────────────────────────────────────────────────────────────
PORT=8080
HOST=127.0.0.1

# ───────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Supabase (for remote sync)
# Uncomment and fill these to enable Supabase synchronization
# Leave blank to run in local-only mode
# ───────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ───────────────────────────────────────────────────────────────────────────────
# LEGACY: OpenClaw directory (used by some scripts)
# ───────────────────────────────────────────────────────────────────────────────
OPENCLAW_DIR=~/.openclaw
